# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
# Optional: falls back to RENDER_EXTERNAL_URL (set automatically by Render)
# or http://localhost:3000 if unset. Used to build links in emails.
APP_URL=http://localhost:3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Swagger UI is always on outside production; in production it's off unless
# explicitly enabled here (useful for a public demo deployment).
SWAGGER_ENABLED=false

# ---------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas_auth?schema=public

# ---------------------------------------------------------------------------
# Bootstrap admin (seed-only, not read by the app at runtime)
# Register this email normally first, then run `npx prisma db seed` to grant
# it the "admin" role. Safe to unset/remove after the first admin exists.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=

# ---------------------------------------------------------------------------
# Redis (sessions, token blacklist, rate limiting)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ---------------------------------------------------------------------------
# JWT / Tokens
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=atlas-auth
JWT_AUDIENCE=atlas-auth-clients

# ---------------------------------------------------------------------------
# Cookies
# ---------------------------------------------------------------------------
COOKIE_SECRET=change-me-cookie-secret-min-32-chars-long
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Password hashing (Argon2id)
# ---------------------------------------------------------------------------
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ---------------------------------------------------------------------------
# Account lockout / brute force protection
# ---------------------------------------------------------------------------
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# ---------------------------------------------------------------------------
# Email verification / password reset token TTLs
# ---------------------------------------------------------------------------
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ---------------------------------------------------------------------------
# Mail provider: smtp | resend | sendgrid | mailtrap
# ---------------------------------------------------------------------------
MAIL_PROVIDER=smtp
MAIL_FROM="Atlas Auth <no-reply@atlas-auth.dev>"

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

RESEND_API_KEY=

SENDGRID_API_KEY=

MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASSWORD=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
